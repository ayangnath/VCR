{
  "manifest_version": 3,
  "name": "VCR — Visualization Color Repair (Pyodide)",
  "version": "0.1.0",
  "description": "Recolor SVG charts on the page so they remain readable under color-vision deficiency. Runs entirely in-browser via Pyodide — no localhost server.",
  "permissions": ["activeTab", "scripting", "offscreen"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "VCR — Visualization Color Repair"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*", "file:///*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
